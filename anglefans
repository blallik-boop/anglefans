<script>
// ─── State ───────────────────────────────────────────────────────────────────
let targetAngle = 90;
let playerAngle = 90;
let score = 0;
let round = 1;
let dragging = false;
let gameActive = false;
let feedbackTimer = null;
let revealActive = false;
let revealAnimId = null;

// ─── Canvas refs ─────────────────────────────────────────────────────────────
const canvasL  = document.getElementById('canvas-left');
const canvasR  = document.getElementById('canvas-right');
const canvasOv = document.getElementById('canvas-overlay');
const ctxL  = canvasL.getContext('2d');
const ctxR  = canvasR.getContext('2d');
const ctxOv = canvasOv.getContext('2d');

function resizeCanvases() {
  const panel = document.getElementById('panel-right');
  const rect = panel.getBoundingClientRect();
  const size = Math.min(rect.width - 40, rect.height - 60);
  const s = Math.max(220, size);
  canvasL.width = canvasR.width = s;
  canvasL.height = canvasR.height = s;
  canvasOv.width  = window.innerWidth;
  canvasOv.height = window.innerHeight;
  drawLeft();
  drawRight();
}

// ─── Geometry helpers ─────────────────────────────────────────────────────────
function angleToCanvas(deg) {
  const rad = (deg * Math.PI) / 180;
  return { x: Math.cos(rad), y: -Math.sin(rad) };
}

function pointToAngle(cx, cy, px, py) {
  const dx = px - cx;
  const dy = -(py - cy);
  let deg = Math.atan2(dy, dx) * (180 / Math.PI);
  if (deg < 0) deg += 360;
  return deg;
}

// ─── Drawing ─────────────────────────────────────────────────────────────────
const COLORS = {
  baseline:   '#888',
  arm:        '#e8c547',
  armPlayer:  '#4ec9b0',
  arcFill:    'rgba(232,197,71,0.08)',
  arcFillP:   'rgba(78,201,176,0.10)',
  protractor: 'rgba(255,255,255,0.03)',
  protTick:   'rgba(255,255,255,0.25)',
  protLabel:  'rgba(255,255,255,0.55)',
  pivot:      '#e8c547',
  pivotP:     '#4ec9b0',
};

function drawArm(ctx, cx, cy, R, angle, color, showHandle, handleHighlight) {
  const dir = angleToCanvas(angle);
  const tipX = cx + dir.x * R;
  const tipY = cy + dir.y * R;
  const perpX = -dir.y, perpY = dir.x;
  const arrowLen = R * 0.05;
  const W = ctx.canvas.width;

  ctx.beginPath();
  ctx.moveTo(cx, cy);
  ctx.lineTo(tipX, tipY);
  ctx.strokeStyle = color;
  ctx.lineWidth = 2.5;
  ctx.setLineDash([]);
  ctx.stroke();

  ctx.beginPath();
  ctx.moveTo(tipX, tipY);
  ctx.lineTo(tipX - dir.x*arrowLen + perpX*arrowLen*0.5, tipY - dir.y*arrowLen + perpY*arrowLen*0.5);
  ctx.lineTo(tipX - dir.x*arrowLen - perpX*arrowLen*0.5, tipY - dir.y*arrowLen - perpY*arrowLen*0.5);
  ctx.closePath();
  ctx.fillStyle = color;
  ctx.fill();

  if (showHandle) {
    ctx.beginPath();
    ctx.arc(tipX, tipY, W * 0.025, 0, Math.PI * 2);
    ctx.fillStyle = handleHighlight ? '#fff' : color;
    ctx.fill();
    ctx.strokeStyle = '#000';
    ctx.lineWidth = 1.5;
    ctx.stroke();
  }
}

function drawAnglePanel(ctx, angle, showProtractor, highlight) {
  const W = ctx.canvas.width;
  const H = ctx.canvas.height;
  const cx = W / 2;
  const cy = H / 2 + H * 0.07;
  const R = W * 0.38;

  ctx.clearRect(0, 0, W, H);

  if (showProtractor) {
    // Semi-circle fill
    ctx.beginPath();
    ctx.arc(cx, cy, R, Math.PI, 0, false);
    ctx.lineTo(cx, cy);
    ctx.closePath();
    ctx.fillStyle = COLORS.protractor;
    ctx.fill();

    // Ticks + labels: d=0 on right, d=180 on left
    for (let d = 0; d <= 180; d++) {
      const arcRad = (d * Math.PI) / 180;
      const cos = Math.cos(arcRad);
      const sin = Math.sin(arcRad);
      const isMajor = d % 10 === 0;
      const isMid   = d % 5 === 0 && !isMajor;
      const tickLen = isMajor ? R * 0.10 : isMid ? R * 0.065 : R * 0.04;

      const x1 = cx + cos * R,        y1 = cy - sin * R;
      const x2 = cx + cos * (R-tickLen), y2 = cy - sin * (R-tickLen);

      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(x2, y2);
      ctx.strokeStyle = COLORS.protTick;
      ctx.lineWidth = isMajor ? 1.5 : 0.8;
      ctx.stroke();

      if (isMajor) {
        const lx = cx + cos * (R - tickLen - R * 0.085);
        const ly = cy - sin * (R - tickLen - R * 0.085);
        ctx.save();
        ctx.translate(lx, ly);
        ctx.fillStyle = COLORS.protLabel;
        ctx.font = `${W * 0.028}px 'Courier Prime', monospace`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(d, 0, 0);
        ctx.restore();
      }
    }

    // Outer arc
    ctx.beginPath();
    ctx.arc(cx, cy, R, Math.PI, 0, false);
    ctx.strokeStyle = 'rgba(255,255,255,0.15)';
    ctx.lineWidth = 1;
    ctx.stroke();
  }

  // Angle arc fill
  ctx.beginPath();
  ctx.moveTo(cx, cy);
  ctx.arc(cx, cy, R * 0.55, 0, -(angle * Math.PI / 180), true);
  ctx.closePath();
  ctx.fillStyle = showProtractor ? COLORS.arcFillP : COLORS.arcFill;
  ctx.fill();

  // Baseline
  const baseLen = R * 1.05;
  ctx.beginPath();
  ctx.moveTo(cx - baseLen * 0.15, cy);
  ctx.lineTo(cx + baseLen, cy);
  ctx.strokeStyle = COLORS.baseline;
  ctx.lineWidth = 2;
  ctx.stroke();

  // Arm
  const armColor = showProtractor ? COLORS.armPlayer : COLORS.arm;
  drawArm(ctx, cx, cy, R, angle, armColor, showProtractor, highlight);

  // Pivot dot
  ctx.beginPath();
  ctx.arc(cx, cy, W * 0.014, 0, Math.PI * 2);
  ctx.fillStyle = showProtractor ? COLORS.pivotP : COLORS.pivot;
  ctx.fill();

  // Angle label (right panel only)
  if (showProtractor) {
    const labelDir = angleToCanvas(angle / 2);
    ctx.font = `bold ${W * 0.038}px 'Courier Prime', monospace`;
    ctx.fillStyle = 'rgba(78,201,176,0.9)';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(Math.round(playerAngle) + '°', cx + labelDir.x * R * 0.30, cy + labelDir.y * R * 0.30);
  }
}

function drawLeft()  { drawAnglePanel(ctxL, targetAngle, false, false); }
function drawRight(highlight = false) { drawAnglePanel(ctxR, playerAngle, true, highlight); }

// ─── Overlay arm (slides from left panel to right panel) ─────────────────────
function getPivotScreen(canvasEl) {
  const rect = canvasEl.getBoundingClientRect();
  const W = canvasEl.width, H = canvasEl.height;
  const scaleX = rect.width / W;
  const scaleY = rect.height / H;
  const cx = W / 2, cy = H / 2 + H * 0.07, R = W * 0.38;
  return {
    x: rect.left + cx * scaleX,
    y: rect.top  + cy * scaleY,
    R: R * Math.min(scaleX, scaleY)
  };
}

function drawOverlayArm(px, py, R, angle, color) {
  ctxOv.clearRect(0, 0, canvasOv.width, canvasOv.height);
  const dir = angleToCanvas(angle);
  const tipX = px + dir.x * R;
  const tipY = py + dir.y * R;
  const perpX = -dir.y, perpY = dir.x;
  const arrowLen = R * 0.05;

  ctxOv.save();
  ctxOv.shadowColor = color;
  ctxOv.shadowBlur = 22;

  ctxOv.beginPath();
  ctxOv.moveTo(px, py);
  ctxOv.lineTo(tipX, tipY);
  ctxOv.strokeStyle = color;
  ctxOv.lineWidth = 3;
  ctxOv.setLineDash([]);
  ctxOv.stroke();

  ctxOv.beginPath();
  ctxOv.moveTo(tipX, tipY);
  ctxOv.lineTo(tipX - dir.x*arrowLen + perpX*arrowLen*0.5, tipY - dir.y*arrowLen + perpY*arrowLen*0.5);
  ctxOv.lineTo(tipX - dir.x*arrowLen - perpX*arrowLen*0.5, tipY - dir.y*arrowLen - perpY*arrowLen*0.5);
  ctxOv.closePath();
  ctxOv.fillStyle = color;
  ctxOv.fill();

  ctxOv.beginPath();
  ctxOv.arc(tipX, tipY, R * 0.065, 0, Math.PI * 2);
  ctxOv.fillStyle = color;
  ctxOv.fill();

  ctxOv.beginPath();
  ctxOv.arc(px, py, R * 0.037, 0, Math.PI * 2);
  ctxOv.fillStyle = color;
  ctxOv.fill();

  ctxOv.restore();
}

function clearOverlay() {
  ctxOv.clearRect(0, 0, canvasOv.width, canvasOv.height);
  canvasOv.style.display = 'none';
}

// ─── Reveal animation ─────────────────────────────────────────────────────────
function startReveal(pts) {
  if (revealAnimId) cancelAnimationFrame(revealAnimId);
  revealActive = true;

  let finalColor;
  if      (pts === 3) finalColor = '#ffffff';
  else if (pts === 2) finalColor = '#e8c547';
  else if (pts === 1) finalColor = '#ff8c00';
  else                finalColor = '#e05c5c';

  const travelColor = COLORS.arm; // amber while crossing

  canvasOv.width  = window.innerWidth;
  canvasOv.height = window.innerHeight;
  canvasOv.style.display = 'block';

  const src  = getPivotScreen(canvasL);
  const dest = getPivotScreen(canvasR);

  const DURATION = 1400;
  const HOLD     = 900;
  let startTime  = null;

  function step(ts) {
    if (!startTime) startTime = ts;
    const t = Math.min((ts - startTime) / DURATION, 1);
    // Ease in-out cubic
    const ease = t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2,3)/2;

    const px = src.x + (dest.x - src.x) * ease;
    const py = src.y + (dest.y - src.y) * ease;
    const R  = src.R + (dest.R - src.R) * ease;

    // Only switch to score color when fully arrived
    const color = t >= 1 ? finalColor : travelColor;
    drawOverlayArm(px, py, R, targetAngle, color);

    if (t < 1) {
      revealAnimId = requestAnimationFrame(step);
    } else {
      // Arrived — draw once more with final color
      drawOverlayArm(dest.x, dest.y, dest.R, targetAngle, finalColor);
      setTimeout(() => {
        clearOverlay();
        revealActive = false;
        revealAnimId = null;
        if (score >= 20) endGame();
        else newRound();
      }, HOLD);
    }
  }
  revealAnimId = requestAnimationFrame(step);
}

// ─── Dragging ─────────────────────────────────────────────────────────────────
function getCanvasPos(e, canvas) {
  const rect = canvas.getBoundingClientRect();
  const clientX = e.touches ? e.touches[0].clientX : e.clientX;
  const clientY = e.touches ? e.touches[0].clientY : e.clientY;
  return { x: clientX - rect.left, y: clientY - rect.top };
}

function getCenterAndRadius() {
  const W = canvasR.width, H = canvasR.height;
  return { cx: W/2, cy: H/2 + H*0.07, R: W*0.38 };
}

function isNearHandle(px, py) {
  const { cx, cy, R } = getCenterAndRadius();
  const dir = angleToCanvas(playerAngle);
  return Math.hypot(px - (cx + dir.x*R), py - (cy + dir.y*R)) < canvasR.width * 0.07;
}

canvasR.addEventListener('mousedown', e => {
  if (!gameActive || revealActive) return;
  if (isNearHandle(...Object.values(getCanvasPos(e, canvasR)))) dragging = true;
});

canvasR.addEventListener('mousemove', e => {
  if (!gameActive || revealActive) return;
  const pos = getCanvasPos(e, canvasR);
  if (dragging) {
    const { cx, cy } = getCenterAndRadius();
    let deg = pointToAngle(cx, cy, pos.x, pos.y);
    playerAngle = Math.max(1, Math.min(179, deg));
    drawRight(true);
  } else {
    canvasR.style.cursor = isNearHandle(pos.x, pos.y) ? 'grab' : 'crosshair';
  }
});

canvasR.addEventListener('mouseup',    () => { dragging = false; canvasR.style.cursor = 'crosshair'; });
canvasR.addEventListener('mouseleave', () => { dragging = false; });

canvasR.addEventListener('touchstart', e => {
  e.preventDefault();
  if (!gameActive || revealActive) return;
  const pos = getCanvasPos(e, canvasR);
  if (isNearHandle(pos.x, pos.y)) dragging = true;
}, { passive: false });

canvasR.addEventListener('touchmove', e => {
  e.preventDefault();
  if (!dragging || !gameActive || revealActive) return;
  const pos = getCanvasPos(e, canvasR);
  const { cx, cy } = getCenterAndRadius();
  playerAngle = Math.max(1, Math.min(179, pointToAngle(cx, cy, pos.x, pos.y)));
  drawRight(true);
}, { passive: false });

canvasR.addEventListener('touchend', () => { dragging = false; });

// ─── Game logic ───────────────────────────────────────────────────────────────
function newRound() {
  targetAngle = Math.floor(Math.random() * 178) + 1;
  playerAngle = 90;
  drawLeft();
  drawRight();
  document.getElementById('target-display').textContent = '—°';
  hideFeedback();
}

function showFeedback(text, color) {
  const el = document.getElementById('feedback-msg');
  el.textContent = text;
  el.style.color = color;
  el.style.opacity = '1';
  clearTimeout(feedbackTimer);
  feedbackTimer = setTimeout(hideFeedback, 3000);
}

function hideFeedback() {
  document.getElementById('feedback-msg').style.opacity = '0';
}

function submitAnswer() {
  if (!gameActive || revealActive) return;
  const diff = Math.abs(Math.round(playerAngle) - targetAngle);
  let pts, msg, color;

  if      (diff === 0) { pts = 3; msg = `PERFECT! +3`;              color = '#ffffff'; }
  else if (diff <= 3)  { pts = 2; msg = `CLOSE! ${diff}° off  +2`; color = '#e8c547'; }
  else if (diff <= 5)  { pts = 1; msg = `ALMOST! ${diff}° off  +1`; color = '#ff8c00'; }
  else                 { pts = 0; msg = `${diff}° off — no points`; color = '#e05c5c'; }

  document.getElementById('target-display').textContent = targetAngle + '°';
  score += pts;
  round++;
  updateScoreUI();
  showFeedback(msg, color);
  startReveal(pts);
}

function skipRound() {
  if (!gameActive || revealActive) return;
  document.getElementById('target-display').textContent = targetAngle + '°';
  showFeedback('SKIPPED — ' + targetAngle + '°', 'var(--dim)');
  round++;
  updateScoreUI();
  startReveal(0);
}

function updateScoreUI() {
  document.getElementById('score-display').textContent = score;
  document.getElementById('round-num').textContent = round;
  document.getElementById('score-bar').style.width = Math.min(100, (score/20)*100) + '%';
}

function startGame() {
  score = 0; round = 1; gameActive = true; revealActive = false;
  if (revealAnimId) { cancelAnimationFrame(revealAnimId); revealAnimId = null; }
  clearOverlay();
  document.getElementById('overlay-start').classList.add('hidden');
  document.getElementById('overlay-end').classList.add('hidden');
  updateScoreUI();
  newRound();
}

function endGame() {
  gameActive = false;
  document.getElementById('final-score').textContent = score;
  document.getElementById('final-rounds').textContent = `in ${round-1} round${round-1!==1?'s':''}`;
  document.getElementById('overlay-end').classList.remove('hidden');
}

document.getElementById('submit-btn').addEventListener('click', submitAnswer);
document.getElementById('skip-btn').addEventListener('click', skipRound);

window.addEventListener('resize', () => {
  resizeCanvases();
  canvasOv.width  = window.innerWidth;
  canvasOv.height = window.innerHeight;
});

resizeCanvases();
</script>
</body>
